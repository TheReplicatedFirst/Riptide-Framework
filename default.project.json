{
  "name": "Riptide Framework",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "RiptideShared": {
        "$path": "src/shared"
      },
      "RiptideClient": {
        "$path": "src/client"
      }
    },
    "ServerStorage": {
      "RiptideServer": {
        "$path": "src/server"
      }
    }
  }
}